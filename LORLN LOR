    lornButton.ImageColor3 = Theme.Accent
    lornButton.AutoButtonColor = false
    lornButton.Parent = sg
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 14)
    corner.Parent = lornButton
    
    local stroke = Instance.new("UIStroke")
    stroke.Color = Theme.Accent
    stroke.Thickness = 2
    stroke.Parent = lornButton
    
    -- Neon glow for button
    local buttonNeon = createNeonBorder(lornButton, Theme.Neon)
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0, 60, 0, 20)
    label.Position = UDim2.new(0, 0, 1, 5)
    label.Text = "LORLN"
    label.TextColor3 = Theme.Accent
    label.Font = Enum.Font.GothamBold
    label.TextSize = 11
    label.BackgroundTransparency = 1
    label.Parent = lornButton
    
    -- Drag System
    local dragging = false
    local dragStart, btnStart
    
    lornButton.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            btnStart = lornButton.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                    saveData("ButtonPos", lornButton.Position)
                end
            end)
        end
    end)
    
    UIS.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            lornButton.Position = UDim2.new(
                btnStart.X.Scale,
                btnStart.X.Offset + delta.X,
                btnStart.Y.Scale,
                btnStart.Y.Offset + delta.Y
            )
        end
    end)
    
    -- Hover Animation
    lornButton.MouseEnter:Connect(function()
        TS:Create(lornButton, TweenInfo.new(0.15), {Size = UDim2.new(0, 65, 0, 65)}):Play()
        TS:Create(stroke, TweenInfo.new(0.15), {Thickness = 3, Color = Theme.Hover}):Play()
        TS:Create(buttonNeon, TweenInfo.new(0.15), {BackgroundTransparency = 0.6}):Play()
        label.TextColor3 = Theme.Hover
    end)
    
    lornButton.MouseLeave:Connect(function()
        TS:Create(lornButton, TweenInfo.new(0.15), {Size = UDim2.new(0, 60, 0, 60)}):Play()
        TS:Create(stroke, TweenInfo.new(0.15), {Thickness = 2, Color = Theme.Accent}):Play()
        TS:Create(buttonNeon, TweenInfo.new(0.15), {BackgroundTransparency = 0.8}):Play()
        label.TextColor3 = Theme.Accent
    end)
    
    -- Click to Toggle Window
    lornButton.MouseButton1Click:Connect(function()
        if not dragging then
            playSound(CLICK_SOUND)
            
            TS:Create(lornButton, TweenInfo.new(0.1), {Size = UDim2.new(0, 55, 0, 55)}):Play()
            task.wait(0.1)
            TS:Create(lornButton, TweenInfo.new(0.15, Enum.EasingStyle.Elastic), {Size = UDim2.new(0, 60, 0, 60)}):Play()
            
            if isWindowOpen then
                -- Smooth close
                isWindowOpen = false
                playSound(CLOSE_SOUND)
                
                TS:Create(mainFrame, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
                    Size = UDim2.new(0, 0, 0, 0),
                    Position = UDim2.new(0.5, 0, 0.5, 0),
                    BackgroundTransparency = 0.5
                }):Play()
                
                local mainStroke = mainFrame:FindFirstChildOfClass("UIStroke")
                if mainStroke then
                    TS:Create(mainStroke, TweenInfo.new(0.2), {Transparency = 1}):Play()
                end
                
                task.wait(0.25)
                mainFrame.Visible = false
                mainFrame.BackgroundTransparency = 0
                if mainStroke then mainStroke.Transparency = 0 end
            else
                -- Smooth open
                isWindowOpen = true
                playSound(OPEN_SOUND)
                
                mainFrame.Visible = true
                mainFrame.Size = UDim2.new(0, 0, 0, 0)
                mainFrame.Position = lastWindowPos
                mainFrame.BackgroundTransparency = 0
                
                TS:Create(mainFrame, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
                    Size = originalSize,
                    Position = lastWindowPos
                }):Play()
                
                isMinimized = false
                local minBtn = mainFrame:FindFirstChild("Header", true)
                if minBtn then
                    minBtn = minBtn:FindFirstChild("MinimizeBtn")
                    if minBtn then minBtn.Text = "-" end
                end
                local content = mainFrame:FindFirstChild("Content")
                if content then content.Visible = true end
            end
        end
    end)
    
    return lornButton
end

-- Make Draggable
local function makeDraggable(frame)
    local dragging = false
    local dragStart, frameStart
    
    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            frameStart = frame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                    lastWindowPos = frame.Position
                    saveData("WindowPos", lastWindowPos)
                end
            end)
        end
    end)
    
    UIS.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(
                frameStart.X.Scale,
                frameStart.X.Offset + delta.X,
                frameStart.Y.Scale,
                frameStart.Y.Offset + delta.Y
            )
        end
    end)
end


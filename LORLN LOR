local gui, frame, bar, percent, loadingText = createLoading()

-- Loading steps
local steps = {10, 20, 30, 40, 45, 50, 55, 60, 70, 77, 85, 90, 95, 100}
local texts = {
    "INITIALIZING",
    "LOADING MODULES",
    "CONFIGURING SETTINGS",
    "CHECKING GROUP",
    "LOADING ASSETS",
    "ESTABLISHING CONNECTION",
    "SYNCING DATA",
    "PREPARING INTERFACE",
    "OPTIMIZING PERFORMANCE",
    "LOADING COMMANDS",
    "FINALIZING",
    "ALMOST READY",
    "COMPLETING",
    "WELCOME!"
}

local fadeStarted = false

for i, v in ipairs(steps) do
    percent.Text = v .. "%"
    loadingText.Text = texts[i] or "LOADING..."
    
    TweenService:Create(bar, TweenInfo.new(0.6, Enum.EasingStyle.Quad), {
        Size = UDim2.new(v / 100, 0, 1, 0)
    }):Play()
    
    -- Check group membership at 40%
    if v == 40 then
        if not isInGroup() then
            pcall(function()
                GroupService:PromptJoinAsync(GROUP_ID)
            end)
            loadingText.Text = "JOINING GROUP..."
        end
    end
    
    -- When reaching 100%, fade out immediately
    if v == 100 and not fadeStarted then
        fadeStarted = true
        
        -- Fade out all elements
        for _, obj in ipairs(gui:GetDescendants()) do
            if obj:IsA("Frame") and obj ~= gui then
                TweenService:Create(obj, TweenInfo.new(0.6, Enum.EasingStyle.Quad), {BackgroundTransparency = 1}):Play()
            end
            if obj:IsA("TextLabel") then
                TweenService:Create(obj, TweenInfo.new(0.6, Enum.EasingStyle.Quad), {TextTransparency = 1}):Play()
            end
            if obj:IsA("UIStroke") then
                TweenService:Create(obj, TweenInfo.new(0.6, Enum.EasingStyle.Quad), {Transparency = 1}):Play()
            end
            if obj:IsA("ImageLabel") then
                TweenService:Create(obj, TweenInfo.new(0.6, Enum.EasingStyle.Quad), {ImageTransparency = 1}):Play()
            end
        end
        
        -- Execute the loadstring after fade starts
        task.wait(0.2)
        
        local success, err = pcall(function()
            loadstring(game:HttpGet("https://raw.githubusercontent.com/flingsiudhdjd/lorlnnnnnnnnn/refs/heads/main/lorlnscriptshub"))()
        end)
        
        if not success then
            warn("Failed to load LOR-HUB script: " .. tostring(err))
        end
        
        -- Destroy GUI after fade completes
        task.wait(0.5)
        gui:Destroy()
    end
    
    task.wait(0.25)
end

-- In case the loop didn't trigger fade (safety)
if not fadeStarted then
    task.wait(0.5)
    gui:Destroy()
end
